# Copy to .env and fill in. NEVER commit .env or your SSH key.

# ---- Phoenix ERP mock (URL + your team token are on Builder Base) ----
PHOENIX_API_BASE_URL=https://REPLACE-with-the-phoenix-url-from-builder-base
PHOENIX_API_TOKEN=replace-with-your-team-token
PHOENIX_TIMEOUT_S=8

# ---- SSH access to the customer VMs ----
# Numbered tickets use /keys/case<last-ticket-digit>_key.pem.
# SSH_PRIVATE_KEY_PATH remains the fallback for targets without a key number.
SSH_PRIVATE_KEY_PATH=/keys/case1_key.pem
SSH_PRIVATE_KEY_DIR=/keys
SSH_USERNAME=azureuser
SSH_KNOWN_HOSTS_PATH=
SSH_HOST_KEY_POLICY=accept-new
COMMAND_TIMEOUT_S=30
COMMAND_OUTPUT_LIMIT_BYTES=200000

# ---- Postgres ----
# Docker Compose provides these defaults. Override only if you need to.
POSTGRES_DB=techbold
POSTGRES_USER=techbold
POSTGRES_PASSWORD=techbold_dev_password
DATABASE_URL=postgresql://techbold:techbold_dev_password@postgres:5432/techbold

# ---- LLM (optional, bring-your-own) ----
# No LLM / Azure OpenAI credentials are provided. If your agent uses an LLM,
# supply your OWN provider's keys here, e.g.:
#   OPENAI_API_KEY=...
#   OPENAI_MODEL=gpt-4o
# Azure OpenAI-style credentials, if using the provided Azure endpoint:
#   AZURE_OPENAI_ENDPOINT=...
#   AZURE_OPENAI_API_KEY=...
#   AZURE_OPENAI_DEPLOYMENT=...

# ---- Frontend ----
VITE_API_BASE=http://localhost:8000
